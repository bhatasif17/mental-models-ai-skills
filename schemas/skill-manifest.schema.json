{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/skill-manifest.schema.json",
  "title": "AI Skill Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "slug",
    "version",
    "category",
    "description",
    "inspired_by",
    "license_notice",
    "risk_level",
    "inputs",
    "outputs",
    "workflow",
    "guardrails",
    "files"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "category": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "inspired_by": {
      "type": "string"
    },
    "license_notice": {
      "type": "string"
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 5
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 5
    },
    "files": {
      "type": "object"
    }
  }
}