{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Run Request",
  "type": "object",
  "required": [
    "skill",
    "input"
  ],
  "properties": {
    "skill": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "default": "standard"
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    }
  }
}